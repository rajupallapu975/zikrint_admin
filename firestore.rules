rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Shops — anyone can read/write shop document (for Zikrinter panel to update walletBalance)
    match /shops/{shopId} {
      allow read, write: if true;

      match /orders/{orderId} {
        allow read, write: if request.auth != null;
      }

      match /transactions/{transactionId} {
        allow read, write: if true;
      }

      match /history/{orderId} {
        allow read, write: if request.auth != null;
      }
    }

    // Services — any authenticated user can read/write
    match /services/{serviceId} {
      allow read, write: if request.auth != null;
    }

    // Withdrawal requests — public read/write so Zikrinter app can approve/reject requests
    match /withdrawal_requests/{reqId} {
      allow read, write: if true;
    }

    // Platform wallet — read/write public so Zikrinter app can update and show earnings
    match /platform/{docId} {
      allow read, write: if true;

      match /transactions/{txId} {
        allow read, write: if true;
      }
    }

    // Allow any user to read app_config
    match /app_config/{document} {
      allow read: if true;
    }
  }
}
